# ── App ────────────────────────────────────────────────────────────────────
DEBUG=false

# ── Auth ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-this-to-a-random-32-char-hex-string

# Default admin password (change this!)
ADMIN_PASSWORD=devagent123

# ── Database ───────────────────────────────────────────────────────────────
# Comment out to use in-memory store (no postgres needed for dev)
DATABASE_URL=postgresql+asyncpg://devagent:devagent@localhost:5432/devagent

# ── GitHub ─────────────────────────────────────────────────────────────────
# Optional: for analyzing private repos
GITHUB_TOKEN=ghp_your_token_here

# ── AI ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here
LLM_MODEL=claude-sonnet-4-20250514

# ── Storage ────────────────────────────────────────────────────────────────
REPOS_BASE_PATH=/tmp/dev-agent-repos
